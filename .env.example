# LINE Bot SDK
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token_here
LINE_CHANNEL_SECRET=your_channel_secret_here

# LIFF（從 LINE Developers Console 建立 LIFF App 取得）
LIFF_ID=your_liff_id_here
# LIFF_ID_UPLOAD：文件上傳頁面（端點 URL: https://your-domain.com/upload-docs）
LIFF_ID_UPLOAD=your_liff_id_upload_here
# LIFF_ID_APPLICATION：申請書填寫頁面（端點 URL: https://your-domain.com/application-form）
LIFF_ID_APPLICATION=your_liff_id_application_here
# LIFF_ID_VALUATE：AI 自動鑑價頁面（端點 URL: https://your-domain.com/valuate）
LIFF_ID_VALUATE=your_liff_id_valuate_here

# 伺服器設定
PORT=3000
BASE_URL=https://xxxx.ngrok-free.app

# 後台管理 API 金鑰（呼叫 /api/admin/* 需帶入 x-admin-api-key header）
ADMIN_API_KEY=your_admin_api_key_here

# Anthropic API（Claude Vision 文件解析）
ANTHROPIC_API_KEY=sk-ant-your_key_here

# ML 鑑價 SubAgent（Python FastAPI，預設 port 8001）
# 啟動方式：uvicorn src.main.python.core.app:app --port 8001 --reload
VALUATION_API_URL=http://localhost:8001

# CREW 3 防詐 PILOT ML 評分服務（Python FastAPI，預設 port 8002）
# 啟動方式：uvicorn src.main.python.services.fraudScoringService:app --port 8002 --reload
FRAUD_SCORING_API_URL=http://localhost:8002

# Power BI Push Dataset（CREW 1/2/3 推論結果 → 行員個案即時儀表板）
# 取得方式：Power BI 工作區 → 資料集 → ... → API 資訊 → 複製 Push URL（含 Key）
# 模式：Push Key（免 Azure AD / Service Principal）
POWER_BI_PUSH_URL=https://api.powerbi.com/beta/{workspace_id}/datasets/{dataset_id}/rows?key=your_push_key_here

# Power Automate Webhook（自動化流程）
# 流程 1：fraud_score > 0.7 → Teams Incoming Webhook 主管警示
POWER_AUTOMATE_FRAUD_WEBHOOK_URL=https://xxx.webhook.office.com/webhookb2/your_teams_incoming_webhook_url

# SharePoint PDF 歸檔（Microsoft Graph API 直接上傳，不需 Power Automate Premium）
# 取得方式：Azure AD 應用程式 → API 權限 → 新增 Sites.ReadWrite.All（應用程式權限）→ 授予管理員同意
# 若已設定 POWER_BI_TENANT/CLIENT/SECRET，可不重複填寫（自動 fallback）
SHAREPOINT_SITE_ID=your_sharepoint_site_id_here
# SHAREPOINT_TENANT_ID=your_azure_tenant_id（選填，未填則 fallback 至 POWER_BI_TENANT_ID）
# SHAREPOINT_CLIENT_ID=your_app_client_id（選填，未填則 fallback 至 POWER_BI_CLIENT_ID）
# SHAREPOINT_CLIENT_SECRET=your_app_client_secret（選填，未填則 fallback 至 POWER_BI_CLIENT_SECRET）

# 行員 LINE User IDs（逗號分隔，CREW3 alertLevel=3 高風險時推播警示 Flex）
STAFF_LINE_USER_IDS=Uxxxx1,Uxxxx2

# 台語語音辨識（Breeze-ASR-26，選填，未設定自動走 Demo 模式）
# 啟動方式：python scripts/breeze-asr-service.py（首次下載模型 ~4-6GB）
BREEZE_ASR_URL=http://localhost:8003/transcribe

# 不動產市場週報排程（每週一 09:00 台灣時間自動推播給訂閱者）
# 訂閱名單儲存於 data/market-subscribers.json
# 手動觸發：POST /api/admin/market-push/trigger（需 x-admin-api-key header）
